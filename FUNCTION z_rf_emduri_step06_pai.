FORM get_pack_material .
  DATA: ls_content_query TYPE /scwm/s_ps_content_query,
        lt_ps_keys       TYPE /scwm/tt_ps_header_key,
        lt_object        TYPE /scwm/tt_ps_object,
        lv_severity	     TYPE	bapi_mtype,
        lt_return	       TYPE	bapirettab.

  APPEND VALUE #( matid = gt_items[ 1 ]-product-productid ) TO ls_content_query-matid.

  CALL FUNCTION '/SCWM/API_PACKSPEC_GETLIST'
    EXPORTING
      is_content_query = ls_content_query
*     IT_PSID_RNG      =
*     IT_PSGROUP_RNG   =
*     IT_CREATED_ON_RNG       =
*     IT_CREATED_BY_RNG       =
*     IT_CHANGED_ON_RNG       =
*     IT_CHANGED_BY_RNG       =
*     IT_ACT_BY_RNG    =
*     IT_ACT_ON_RNG    =
*     IT_STATUS_RNG    =
*     IV_LOGSYS        =
    IMPORTING
      et_ps_keys       = lt_ps_keys
      ev_severity      = lv_severity
      et_return        = lt_return
* CHANGING
*     CV_MAX_ROWS      =
    .

  CALL FUNCTION '/SCWM/API_PACKSPEC_READ'
    EXPORTING
*     IS_FLAGS    =
      it_ps_id    = lt_ps_keys
    IMPORTING
      et_object   = lt_object
      ev_severity = lv_severity
      et_return   = lt_return.
  IF sy-subrc = 0.
    gs_scr7-ps_id = lt_object[ 1 ]-levels[ 1 ]-hu_mat.
  ENDIF.

ENDFORM.
